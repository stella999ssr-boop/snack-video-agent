# DashScope API Key（通义千问 + 通义万相）
# 从 https://dashscope.console.aliyun.com/ 获取
DASHSCOPE_API_KEY=sk-your-key-here

# 运行模式: demo（本地规则，无需 API） / live（LLM + 视频生成）
AGENT_MODE=demo

# live 模式下是否生成 Wan2.2 视频（耗时且产生费用）
LIVE_ENABLE_VIDEO=false

# 本地文件与数据库；Railway 部署时统一放到 /data Volume
SQLITE_PATH=./data/snack_agent.db
CHROMA_PATH=./data/chroma
UPLOAD_DIR=./static/uploads
OUTPUT_DIR=./static/outputs

# 公网部署必须设置；只填在 Railway Variables，不要提交真实密码
SITE_ACCESS_PASSWORD=请设置一个仅自己知道的访问密码

# 服务地址和端口
HOST=127.0.0.1
PORT=8000
